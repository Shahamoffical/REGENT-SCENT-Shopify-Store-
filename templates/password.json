{
  "layout": "password",
  "sections": {
    "main": {
      "type": "password",
      "blocks": {
        "logo": {
          "type": "logo",
          "name": "t:names.logo",
          "settings": {
            "unit": "pixel",
            "pixel_height": 24,
            "unit_mobile": "percent",
            "percent_width_mobile": 80,
            "padding-block-end": 32
          }
        },
        "text": {
          "type": "text",
          "name": "t:names.text",
          "settings": {
            "text": "<h1>Opening soon</h1>",
            "type_preset": "h3"
          }
        },
        "text-2": {
          "type": "text",
          "name": "t:names.text",
          "settings": {
            "text": "<p>Sign up for our newsletter to be the first to know when we launch.</p>",
            "padding-block-end": 32
          }
        },
        "email-signup": {
          "type": "email-signup",
          "name": "t:names.email_signup",
          "settings": {
            "width": "custom",
            "custom_width": 50,
            "input_style": "custom",
            "input_background_color": "{{ settings.color_palette.background }}",
            "input_text_color": "{{ settings.color_palette.foreground }}",
            "input_border_color": "{{ settings.color_palette.foreground }}"
          }
        }
      },
      "block_order": [
        "logo",
        "text",
        "text-2",
        "email-signup"
      ],
      "name": "t:names.password",
      "settings": {
        "horizontal_alignment": "center",
        "vertical_alignment": "center",
        "horizontal_alignment_flex_direction_column": "center",
        "vertical_alignment_flex_direction_column": "center",
        "gap": 12,
        "section_width": "page-width",
        "background_color": "{{ settings.color_palette.background }}"
      }
    }
  },
  "order": [
    "main"
  ]
}