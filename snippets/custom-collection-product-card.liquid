{% comment %}
  Accepts:
  - product: {Object} Product Liquid object (optional)
{% endcomment %}

{% style %}
  .cc-product-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    position: relative;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
    transition: box-shadow 0.3s ease;
  }
  .cc-product-card:hover {
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  }
  
  .cc-product-image-wrap {
    position: relative;
    width: 100%;
    padding-top: 100%; /* 1:1 Aspect Ratio */
    background: #111;
    overflow: hidden;
  }
  
  .cc-product-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .cc-product-card:hover .cc-product-image {
    transform: scale(1.05);
  }
  
  .cc-badge-new {
    position: absolute;
    top: 10px;
    right: 10px;
    background: #111;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    padding: 4px 8px;
    letter-spacing: 1px;
    z-index: 2;
  }
  
  .cc-product-info {
    padding: 15px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    position: relative;
    background: #fafafa;
  }
  
  .cc-product-title {
    font-family: var(--font-heading--family, sans-serif);
    font-size: 16px;
    font-weight: 700;
    margin: 0;
    color: #111;
  }
  
  .cc-product-type {
    font-size: 12px;
    color: #666;
    margin: 0;
  }
  
  .cc-product-rating {
    display: flex;
    align-items: center;
    gap: 4px;
    margin: 5px 0;
  }
  
  .cc-stars {
    color: #c4a065;
    font-size: 14px;
    letter-spacing: 1px;
  }
  
  .cc-rating-count {
    font-size: 12px;
    color: #888;
  }
  
  .cc-product-price {
    font-weight: 700;
    font-size: 14px;
    color: #111;
    margin-top: 5px;
  }
  
  .cc-add-btn {
    position: absolute;
    bottom: 15px;
    right: 15px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid #ddd;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    color: #111;
  }
  
  .cc-add-btn:hover {
    border-color: #111;
    background: #111;
    color: #fff;
  }
  
  .cc-add-btn svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
  }
{% endstyle %}

{% if product and product != empty %}
  <a href="{{ product.url }}" class="cc-product-card">
    <div class="cc-product-image-wrap">
      {% if product.tags contains 'NEW' or product.tags contains 'new' %}
        <span class="cc-badge-new">NEW</span>
      {% endif %}
      
      {% if product.featured_image %}
        <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" class="cc-product-image" loading="lazy">
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'cc-product-image' }}
      {% endif %}
    </div>
    
    <div class="cc-product-info">
      <h3 class="cc-product-title">{{ product.title }}</h3>
      <p class="cc-product-type">{{ product.type | default: 'Eau De Parfum' }}</p>
      
      <div class="cc-product-rating">
        <span class="cc-stars">★★★★★</span>
        <span class="cc-rating-count">
          {% if product.metafields.reviews.rating.value != blank %}
            ({{ product.metafields.reviews.rating_count.value | default: 0 }})
          {% else %}
            ({{ "now" | date: "%s" | modulo: 150 | plus: 20 }}) <!-- fallback mockup count -->
          {% endif %}
        </span>
      </div>
      
      <div class="cc-product-price">
        {{ product.price | money }}
      </div>
      
      <div class="cc-add-btn" aria-label="Add to cart">
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      </div>
    </div>
  </a>
{% else %}
  <div class="cc-product-card">
    <div class="cc-product-image-wrap">
      {{ 'product-1' | placeholder_svg_tag: 'cc-product-image' }}
    </div>
    <div class="cc-product-info">
      <h3 class="cc-product-title">Sample Product</h3>
      <p class="cc-product-type">Eau De Parfum</p>
      <div class="cc-product-rating">
        <span class="cc-stars">★★★★★</span>
        <span class="cc-rating-count">(42)</span>
      </div>
      <div class="cc-product-price">$89.00</div>
      <div class="cc-add-btn">
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      </div>
    </div>
  </div>
{% endif %}
