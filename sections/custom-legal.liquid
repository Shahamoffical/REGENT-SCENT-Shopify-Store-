{% style %}
  /* ==========================================================================
     Custom Legal – all classes prefixed "custom-legal-"
     ========================================================================== */
  .custom-legal-container {
    width: 100%;
    box-sizing: border-box;
    padding-left: 20px;
    padding-right: 20px;
    background-color: {{ section.settings.bg_color }};
  }
  .custom-legal-container--780 {
    max-width: 800px;
    margin: 0 auto;
  }
  .custom-legal-section { 
    padding-top: {{ section.settings.padding_top }}px; 
    padding-bottom: {{ section.settings.padding_bottom }}px; 
  }

  .custom-legal h1 {
    font-family: var(--font-heading--family, sans-serif);
    font-weight: 700;
    font-size: clamp(30px, 4.5vw, 46px);
    margin: 0 0 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
  }
  
  .custom-legal__meta {
    font-family: var(--font-body--family, sans-serif);
    font-size: 13px;
    color: #888888;
    margin-bottom: 30px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .custom-legal__sections {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }
  
  .custom-legal__sections h2 {
    font-family: var(--font-heading--family, sans-serif);
    font-weight: 600;
    font-size: 20px;
    margin: 0 0 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: {{ section.settings.subheading_color }};
  }
  
  .custom-legal__sections p {
    font-family: var(--font-body--family, sans-serif);
    margin: 0 0 12px;
    font-size: 15px;
    line-height: 1.7;
    color: {{ section.settings.text_color }};
  }
  
  .custom-legal__sections ul {
    font-family: var(--font-body--family, sans-serif);
    margin: 5px 0 0;
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  
  .custom-legal__sections li {
    font-size: 15px;
    line-height: 1.7;
    color: {{ section.settings.text_color }};
  }

  @media (max-width: 600px) {
    .custom-legal-container { padding-left: 16px; padding-right: 16px; }
    .custom-legal h1 { font-size: 28px; }
  }
{% endstyle %}

<section class="custom-legal-container custom-legal-section custom-legal">
  <div class="custom-legal-container--780">
    {% if section.settings.title != blank %}
      <h1>{{ section.settings.title }}</h1>
    {% endif %}
    
    {% if section.settings.meta != blank %}
      <div class="custom-legal__meta">{{ section.settings.meta }}</div>
    {% endif %}
    
    <div class="custom-legal__sections">
      {% for block in section.blocks %}
        <div {{ block.shopify_attributes }}>
          {% if block.settings.heading != blank %}
            <h2>{{ block.settings.heading }}</h2>
          {% endif %}
          
          {% if block.settings.body != blank %}
            {% assign paras = block.settings.body | newline_to_br | split: '<br />' %}
            {% for para in paras %}
              {% assign trimmed = para | strip %}
              {% if trimmed != blank %}<p>{{ trimmed }}</p>{% endif %}
            {% endfor %}
          {% endif %}
          
          {% if block.settings.list_items != blank %}
            {% assign items = block.settings.list_items | newline_to_br | split: '<br />' %}
            <ul>
              {% for item in items %}
                {% assign trimmed_item = item | strip %}
                {% if trimmed_item != blank %}<li>{{ trimmed_item }}</li>{% endif %}
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Legal",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#c4a065"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Page title",
      "default": "Privacy Policy"
    },
    {
      "type": "text",
      "id": "meta",
      "label": "Meta line (e.g. dates)",
      "default": "Last updated: 1 January 2025"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "section",
      "name": "Legal section",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading (optional)"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Paragraphs",
          "info": "One paragraph per line."
        },
        {
          "type": "textarea",
          "id": "list_items",
          "label": "Bullet list items",
          "info": "One item per line (optional)."
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Custom Legal",
      "blocks": [
        {
          "type": "section",
          "settings": {
            "heading": "1. Introduction",
            "body": "Welcome to our privacy policy. We respect your privacy and are committed to protecting your personal data."
          }
        },
        {
          "type": "section",
          "settings": {
            "heading": "2. Data We Collect",
            "body": "We may collect, use, store and transfer different kinds of personal data about you which we have grouped together as follows:",
            "list_items": "Identity Data includes first name, last name.\nContact Data includes email address and telephone numbers.\nTechnical Data includes internet protocol (IP) address."
          }
        }
      ]
    }
  ]
}
{% endschema %}
