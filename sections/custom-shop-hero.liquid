{% style %}
  .custom-shop-hero {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: #000;
  }
  .csh-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  .csh-bg-mobile {
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  .csh-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    z-index: 2;
  }
  .csh-content {
    position: relative;
    z-index: 3;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    padding: {{ section.settings.padding_top }}px 40px {{ section.settings.padding_bottom }}px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    min-height: {{ section.settings.desktop_height }}px;
  }
  .csh-heading {
    font-family: var(--font-heading--family, serif);
    font-size: 52px;
    font-weight: 500;
    color: #ffffff;
    margin: 0 0 10px 0;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .csh-breadcrumbs {
    font-family: var(--font-body--family, sans-serif);
    font-size: 13px;
    color: #cccccc;
    display: flex;
    align-items: center;
    gap: 8px;
    letter-spacing: 0.5px;
  }
  .csh-breadcrumbs a {
    color: #cccccc;
    text-decoration: none;
    transition: color 0.2s;
  }
  .csh-breadcrumbs a:hover {
    color: #ffffff;
  }
  .csh-breadcrumbs span.separator {
    font-size: 10px;
  }
  .csh-breadcrumbs span.current {
    color: #ffffff;
  }

  /* Mobile Styles */
  @media screen and (max-width: 768px) {
    .csh-content {
      padding: 40px 20px;
      min-height: {{ section.settings.mobile_height }}px;
    }
    .csh-heading {
      font-size: 36px;
    }
    .csh-bg.has-mobile {
      display: none;
    }
    .csh-bg-mobile.is-mobile {
      display: block;
    }
  }
{% endstyle %}

<div class="custom-shop-hero">
  {% if section.settings.image != blank %}
    <img src="{{ section.settings.image | image_url: width: 2000 }}" alt="{{ section.settings.heading }}" class="csh-bg {% if section.settings.mobile_image != blank %}has-mobile{% endif %}" loading="eager">
    {% if section.settings.mobile_image != blank %}
      <img src="{{ section.settings.mobile_image | image_url: width: 800 }}" alt="{{ section.settings.heading }}" class="csh-bg-mobile is-mobile" loading="eager">
    {% endif %}
  {% else %}
    {{ 'lifestyle-2' | placeholder_svg_tag: 'csh-bg' }}
  {% endif %}
  
  <div class="csh-overlay"></div>
  
  <div class="csh-content">
    {% if section.settings.heading != blank %}
      <h1 class="csh-heading">{{ section.settings.heading }}</h1>
    {% endif %}
    
    {% if section.settings.show_breadcrumbs %}
      <nav class="csh-breadcrumbs" aria-label="breadcrumbs">
        <a href="{{ routes.root_url }}">Home</a>
        <span class="separator">›</span>
        {% if template contains 'collection' and collection.handle %}
          <span class="current">{{ collection.title }}</span>
        {% elsif template == 'list-collections' %}
          <span class="current">Collections</span>
        {% else %}
          <span class="current">{{ section.settings.default_breadcrumb | default: 'Shop' }}</span>
        {% endif %}
      </nav>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Custom Shop Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Background Image (Optional)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "%"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP ALL"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show Breadcrumbs",
      "default": true
    },
    {
      "type": "text",
      "id": "default_breadcrumb",
      "label": "Default Breadcrumb Text",
      "info": "Used if not on a specific collection page.",
      "default": "Shop"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop Minimum Height",
      "min": 100,
      "max": 600,
      "step": 10,
      "default": 200,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile Minimum Height",
      "min": 100,
      "max": 600,
      "step": 10,
      "default": 150,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Custom Shop Hero"
    }
  ]
}
{% endschema %}
