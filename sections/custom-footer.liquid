{% style %}
  .custom-footer-wrapper {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 40px {{ section.settings.padding_bottom }}px;
    width: 100%;
    box-sizing: border-box;
    font-family: var(--font-body--family, sans-serif);
    color: #ffffff;
  }
  .cf-container {
    max-width: 1400px;
    margin: 0 auto;
  }
  .cf-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 40px;
  }
  
  /* Brand Info Block */
  .cf-block-brand {
    flex: 2 1 300px; /* Takes up more space */
    max-width: 400px;
  }
  .cf-logo {
    max-width: 200px;
    height: auto;
    margin-bottom: 25px;
    display: block;
  }
  .cf-logo-placeholder {
    font-family: var(--font-heading--family, sans-serif);
    font-size: 24px;
    font-weight: 700;
    color: #c4a065;
    margin-bottom: 25px;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .cf-tagline {
    font-size: 13px;
    line-height: 1.6;
    color: #a0a0a0;
    margin-bottom: 25px;
  }
  .cf-socials {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .cf-social-link {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #a0a0a0;
    font-size: 13px;
    line-height: 1.5;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .cf-social-link svg {
    width: 18px;
    height: 18px;
    fill: #c4a065;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .cf-social-link:hover {
    color: #c4a065;
  }

  /* Link List Block */
  .cf-block-links {
    flex: 1 1 150px;
  }
  .cf-heading {
    font-family: var(--font-heading--family, sans-serif);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #ffffff;
    margin: 0 0 20px 0;
  }
  .cf-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .cf-menu li {
    margin-bottom: 12px;
  }
  .cf-menu a {
    color: #a0a0a0;
    text-decoration: none;
    font-size: 13px;
    transition: color 0.3s ease;
  }
  .cf-menu a:hover {
    color: #c4a065;
  }

  /* Contact Info Block */
  .cf-block-contact {
    flex: 1 1 200px;
  }
  .cf-contact-details {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .cf-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #a0a0a0;
    font-size: 13px;
    line-height: 1.5;
  }
  .cf-contact-item svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: #c4a065;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .cf-contact-item a {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s;
  }
  .cf-contact-item a:hover {
    color: #c4a065;
  }

  /* Responsive */
  @media screen and (max-width: 900px) {
    .cf-grid {
      gap: 30px;
    }
    .cf-block-brand {
      flex: 1 1 100%;
      max-width: 100%;
      margin-bottom: 20px;
    }
    .cf-block-links {
      flex: 1 1 calc(50% - 15px);
    }
  }
  
  @media screen and (max-width: 600px) {
    .cf-block-links {
      flex: 1 1 100%;
    }
    .custom-footer-wrapper {
      padding-left: 20px;
      padding-right: 20px;
    }
  }
{% endstyle %}

<div class="custom-footer-wrapper">
  <div class="cf-container">
    <div class="cf-grid">
      {% for block in section.blocks %}
        {% case block.type %}
          
          {% when 'brand_info' %}
            <div class="cf-block-brand" {{ block.shopify_attributes }}>
              {% if block.settings.logo != blank %}
                <img src="{{ block.settings.logo | image_url: width: 400 }}" alt="Regent Scent" class="cf-logo" loading="lazy">
              {% else %}
                <div class="cf-logo-placeholder">Regent Scent</div>
              {% endif %}
              
              {% if block.settings.tagline != blank %}
                <div class="cf-tagline">{{ block.settings.tagline }}</div>
              {% endif %}
              
              {% if block.settings.show_socials %}
                <div class="cf-socials">
                  {% assign fb_link = block.settings.facebook_link | default: settings.social_facebook_link %}
                  {% if fb_link != blank %}
                    <a href="{{ fb_link }}" class="cf-social-link" target="_blank" rel="noopener" aria-label="Facebook">
                      <svg viewBox="0 0 24 24" style="fill:none; stroke:#c4a065; stroke-width:2; stroke-linecap:round; stroke-linejoin:round;"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                      <span>Facebook</span>
                    </a>
                  {% endif %}
                  {% assign ig_link = block.settings.instagram_link | default: settings.social_instagram_link %}
                  {% if ig_link != blank %}
                    <a href="{{ ig_link }}" class="cf-social-link" target="_blank" rel="noopener" aria-label="Instagram">
                      <svg viewBox="0 0 24 24" style="fill:none; stroke:#c4a065; stroke-width:2; stroke-linecap:round; stroke-linejoin:round;"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                      <span>Instagram</span>
                    </a>
                  {% endif %}
                  {% if settings.social_tiktok_link != blank %}
                    <a href="{{ settings.social_tiktok_link }}" class="cf-social-link" target="_blank" rel="noopener" aria-label="TikTok">
                      <svg viewBox="0 0 24 24"><path d="M9 0h1.98c.144 5.994 5.038 7.338 7.994 7.42v3.023c-2.228-.08-4.887-.936-6.495-2.616v7.712c0 5.433-5.26 9.467-10.373 7.502C-1.895 21.528-1.01 13.98 4.606 13.204v3.136c-2.122.257-3.15 2.583-2.213 4.417.882 1.728 3.518 1.936 4.626-.145V0h1.98z"/></svg>
                      <span>TikTok</span>
                    </a>
                  {% endif %}
                  {% if settings.social_pinterest_link != blank %}
                    <a href="{{ settings.social_pinterest_link }}" class="cf-social-link" target="_blank" rel="noopener" aria-label="Pinterest">
                      <svg viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.951-7.252 4.168 0 7.41 2.967 7.41 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.367 18.624 0 12.017 0z"/></svg>
                      <span>Pinterest</span>
                    </a>
                  {% endif %}
                </div>
              {% endif %}
            </div>

          {% when 'link_list' %}
            <div class="cf-block-links" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <h4 class="cf-heading">{{ block.settings.heading }}</h4>
              {% endif %}
              
              {% if block.settings.menu != blank %}
                <ul class="cf-menu">
                  {% for link in block.settings.menu.links %}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {% endfor %}
                </ul>
              {% else %}
                <ul class="cf-menu">
                  <li><a href="#">Example Link 1</a></li>
                  <li><a href="#">Example Link 2</a></li>
                  <li><a href="#">Example Link 3</a></li>
                </ul>
              {% endif %}
            </div>

          {% when 'contact_info' %}
            <div class="cf-block-contact" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <h4 class="cf-heading">{{ block.settings.heading }}</h4>
              {% endif %}
              <div class="cf-contact-details">
                {% if block.settings.phone != blank %}
                  <div class="cf-contact-item">
                    <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    <span>{{ block.settings.phone }}</span>
                  </div>
                {% endif %}
                {% if block.settings.email != blank %}
                  <div class="cf-contact-item">
                    <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    <a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a>
                  </div>
                {% endif %}
                {% if block.settings.location != blank %}
                  <div class="cf-contact-item">
                    <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <span>{{ block.settings.location | newline_to_br }}</span>
                  </div>
                {% endif %}
              </div>
            </div>

        {% endcase %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#101010"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 80,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "brand_info",
      "name": "Brand Info",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image"
        },
        {
          "type": "richtext",
          "id": "tagline",
          "label": "Tagline Text",
          "default": "<p>Crafted with passion. Made for memories. Designed for you.</p>"
        },
        {
          "type": "checkbox",
          "id": "show_socials",
          "label": "Show Social Media Icons",
          "info": "To show your social icons, enter links below or in your Theme Settings > Social Media.",
          "default": true
        },
        {
          "type": "url",
          "id": "facebook_link",
          "label": "Facebook Link (Overrides Theme Settings)"
        },
        {
          "type": "url",
          "id": "instagram_link",
          "label": "Instagram Link (Overrides Theme Settings)"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu Links",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Select Menu"
        }
      ]
    },
    {
      "type": "contact_info",
      "name": "Contact Info",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Contact Us"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone Number",
          "default": "+1 (555) 123-4567"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email Address",
          "default": "support@regentscent.com"
        },
        {
          "type": "textarea",
          "id": "location",
          "label": "Location",
          "default": "123 Fragrance Lane\nNew York, NY 10001"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer",
      "blocks": [
        {
          "type": "brand_info"
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "SHOP"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "CUSTOMER CARE"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "ABOUT"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "LEGAL"
          }
        },
        {
          "type": "contact_info"
        }
      ]
    }
  ]
}
{% endschema %}
