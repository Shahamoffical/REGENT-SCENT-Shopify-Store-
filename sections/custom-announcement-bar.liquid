{% style %}
  .custom-announcement-bar-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
    display: flex;
    justify-content: {{ section.settings.text_alignment }};
    align-items: center;
  }
  
  .custom-announcement-bar-{{ section.id }} .cab-text {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.font_size }}px;
    font-weight: {{ section.settings.font_weight }};
    text-transform: {% if section.settings.uppercase %}uppercase{% else %}none{% endif %};
    letter-spacing: {{ section.settings.letter_spacing }}px;
    margin: 0;
    display: flex;
    align-items: center;
    gap: {{ section.settings.gap }}px;
    white-space: nowrap;
  }

  @media screen and (max-width: 768px) {
    .custom-announcement-bar-{{ section.id }} {
      overflow: hidden;
      justify-content: flex-start;
      padding-left: 0;
      padding-right: 0;
    }
    
    .custom-announcement-bar-{{ section.id }} .cab-text {
      animation: marquee 30s linear infinite;
    }
  }

  @keyframes marquee {
    0% {
      transform: translateX(100vw);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  .custom-announcement-bar-{{ section.id }} .cab-text a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .custom-announcement-bar-{{ section.id }} .cab-text a:hover {
    opacity: 0.8;
  }

  .custom-announcement-bar-{{ section.id }} .cab-divider {
    color: {{ section.settings.text_color }};
    opacity: 0.7;
    font-weight: 300;
  }
{% endstyle %}

<div class="custom-announcement-bar-{{ section.id }}">
  <div class="cab-text">
    {% for block in section.blocks %}
      {% if block.settings.link != blank %}
        <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
      {% else %}
        <span>{{ block.settings.text }}</span>
      {% endif %}
      
      {% unless forloop.last %}
        <span class="cab-divider">|</span>
      {% endunless %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Custom Announcement Bar",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#c4a065"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 12
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "checkbox",
      "id": "uppercase",
      "label": "Uppercase Text",
      "default": true
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "label": "Letter Spacing",
      "default": 1
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-end"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 5,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Spacing Between Items",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Horizontal Padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Announce something here"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Announcement Bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "FREE SHIPPING ON ORDERS OVER $99"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "10% OFF YOUR FIRST ORDER"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "SIGN UP NOW"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
