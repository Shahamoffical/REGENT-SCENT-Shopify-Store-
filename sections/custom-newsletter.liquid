{% style %}
  .custom-newsletter-wrapper {
    position: relative;
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    width: 100%;
    box-sizing: border-box;
    background-color: #111;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
  }
  
  .cn-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    z-index: 1;
  }
  
  .cn-container {
    position: relative;
    z-index: 2;
    max-width: 600px;
    width: 100%;
    text-align: center;
  }
  
  .cn-heading {
    font-family: var(--font-heading--family, sans-serif);
    font-size: 18px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #c4a065;
    margin: 0 0 10px 0;
  }
  
  .cn-subheading {
    font-family: var(--font-body--family, sans-serif);
    font-size: 14px;
    color: #ffffff;
    margin: 0 0 25px 0;
  }
  
  .cn-form-wrapper {
    width: 100%;
  }
  
  .cn-form {
    display: flex;
    width: 100%;
    max-width: 500px;
    margin: 0 auto;
    gap: 10px;
  }
  
  .cn-input {
    flex: 1;
    padding: 12px 15px;
    font-family: var(--font-body--family, sans-serif);
    font-size: 14px;
    border: none;
    background-color: #ffffff;
    color: #333;
    outline: none;
  }
  
  .cn-input::placeholder {
    color: #888;
  }
  
  .cn-button {
    background-color: #c4a065;
    color: #000;
    border: none;
    padding: 12px 25px;
    font-family: var(--font-heading--family, sans-serif);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }
  
  .cn-button:hover {
    background-color: #e6be7b;
  }
  
  .cn-success {
    color: #c4a065;
    font-size: 14px;
    margin-bottom: 15px;
  }
  
  .cn-error {
    color: #ff6b6b;
    font-size: 14px;
    margin-bottom: 15px;
  }

  /* Responsive Styling */
  @media screen and (max-width: 600px) {
    .cn-form {
      flex-direction: column;
      gap: 10px;
    }
    .cn-input, .cn-button {
      width: 100%;
      box-sizing: border-box;
    }
  }
{% endstyle %}

<div class="custom-newsletter-wrapper" 
     {% if section.settings.image != blank %}
       style="background-image: url('{{ section.settings.image | image_url: width: 2000 }}');"
     {% endif %}>
  
  <div class="cn-overlay"></div>
  
  <div class="cn-container">
    {% if section.settings.heading != blank %}
      <h2 class="cn-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.subheading != blank %}
      <p class="cn-subheading">{{ section.settings.subheading }}</p>
    {% endif %}
    
    <div class="cn-form-wrapper">
      {% form 'customer', class: 'cn-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        
        {%- if form.posted_successfully? -%}
          <div class="cn-success" style="width: 100%;">
            Thank you for subscribing!
          </div>
        {%- elsif form.errors -%}
          <div class="cn-error" style="width: 100%;">
            {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
          </div>
        {%- endif -%}

        {%- unless form.posted_successfully? -%}
          <input 
            type="email" 
            name="contact[email]" 
            class="cn-input" 
            value="{% if customer %}{{ customer.email }}{% endif %}" 
            placeholder="Enter your email address" 
            aria-required="true"
            autocorrect="off" 
            autocapitalize="off" 
            required>
          <button type="submit" class="cn-button">
            {{ section.settings.button_text }}
          </button>
        {%- endunless -%}
      {% endform %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Newsletter",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 70,
      "unit": "%"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "STAY IN THE SCENT"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Subscribe to get exclusive offers, early access & more."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SUBSCRIBE"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 80,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Custom Newsletter"
    }
  ]
}
{% endschema %}
