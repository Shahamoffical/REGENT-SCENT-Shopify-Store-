{% style %}
  .custom-tb-wrapper {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    width: 100%;
    box-sizing: border-box;
    font-family: var(--font-body--family, sans-serif);
    border-top: 1px solid #222; /* Subtle separation if needed */
    border-bottom: 1px solid #222;
  }
  .ctb-container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .ctb-grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | default: 4 }}, 1fr);
    gap: 20px;
    align-items: center;
  }
  
  .ctb-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
  }
  
  .ctb-icon {
    width: 35px;
    height: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  
  .ctb-icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: #c4a065;
    stroke-width: 1.5;
  }
  
  .ctb-text {
    display: flex;
    flex-direction: column;
  }
  
  .ctb-heading {
    font-family: var(--font-heading--family, sans-serif);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #c4a065;
    margin: 0 0 4px 0;
  }
  
  .ctb-subheading {
    font-size: 12px;
    color: #eeeeee;
    margin: 0;
  }

  /* Responsive Styling */
  @media screen and (max-width: 900px) {
    .ctb-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px 20px;
    }
    .ctb-badge {
      justify-content: flex-start; /* Align left when stacked */
      padding-left: 10%;
    }
  }
  
  @media screen and (max-width: 600px) {
    .ctb-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 25px 10px;
    }
    .ctb-badge {
      flex-direction: column;
      text-align: center;
      justify-content: flex-start;
      padding-left: 0;
      gap: 8px;
    }
  }
{% endstyle %}

<div class="custom-tb-wrapper">
  <div class="ctb-container">
    <div class="ctb-grid">
      {% for block in section.blocks %}
        <div class="ctb-badge" {{ block.shopify_attributes }}>
          <div class="ctb-icon">
            {% if block.settings.custom_svg != blank %}
              {{ block.settings.custom_svg }}
            {% else %}
              <!-- Fallback simple circle if no SVG provided -->
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>
            {% endif %}
          </div>
          <div class="ctb-text">
            {% if block.settings.heading != blank %}
              <h4 class="ctb-heading">{{ block.settings.heading }}</h4>
            {% endif %}
            {% if block.settings.subheading != blank %}
              <p class="ctb-subheading">{{ block.settings.subheading }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Trust Badges",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0d0d0d"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "limit": 4,
      "settings": [
        {
          "type": "html",
          "id": "custom_svg",
          "label": "SVG Icon Code",
          "info": "Paste raw SVG code here."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "FREE SHIPPING"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "On orders over $99"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Trust Badges",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "heading": "FREE SHIPPING",
            "subheading": "On orders over $99",
            "custom_svg": "<svg viewBox=\"0 0 24 24\"><path d=\"M1 3h15v13H1zM16 8h4l3 3v5h-7V8z\"/><circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"/><circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"/></svg>"
          }
        },
        {
          "type": "badge",
          "settings": {
            "heading": "SECURE PAYMENT",
            "subheading": "100% secure checkout",
            "custom_svg": "<svg viewBox=\"0 0 24 24\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\" ry=\"2\"/><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"/></svg>"
          }
        },
        {
          "type": "badge",
          "settings": {
            "heading": "EASY RETURNS",
            "subheading": "30 days return policy",
            "custom_svg": "<svg viewBox=\"0 0 24 24\"><path d=\"M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8\"/><path d=\"M3 3v5h5\"/></svg>"
          }
        },
        {
          "type": "badge",
          "settings": {
            "heading": "24/7 SUPPORT",
            "subheading": "We're here to help",
            "custom_svg": "<svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>"
          }
        }
      ]
